" | Restante: {time_remaining} ({frames_remaining}f) | Velocidad: {speed_fps}"
"fps"

msgid "Examples:"
msgstr "Ejemplos:"

msgid "Restore video with default settings:"
msgstr "Procesar video con la configuración por defecto:"

#, python-format
msgid "%(prog)s --input input.mp4"
msgstr "%(prog)s --input input.mp4"

msgid ""
"Restore all videos found in the specified directory and save them to a "
"different folder:"
msgstr ""
"Procesar todos los vídeos del directorio especificado y guardarlos en una "
"carpeta diferente:"

#, python-format
msgid "%(prog)s --input path/to/input/dir/ --output /path/to/output/dir/"
msgstr "%(prog)s --input path/to/input/dir/ --output /path/to/output/car/"

msgid "Use Nvidia hardware-accelerated encoder by selecting a preset:"
msgstr ""
"Usar codificación acelerada por hardware Nvidia seleccionando una "
"configuración:"

#, python-format
msgid "%(prog)s --input input.mp4 --encoding-preset hevc-nvidia-gpu-hq"
msgstr ""
"%(prog)s --entrada input.mp4 --codificador seleccionado hevc-nvidia-gpu-hq"

msgid "Set encoding parameters directly without using an encoding preset:"
msgstr ""
"Establecer parámetros codificación directamente sin usar ajustes "
"preestablecidos:"

#, python-format
msgid ""
"%(prog)s --input input.mp4 --encoder libx265 --encoder-options '-crf 26 "
"-preset fast -x265-params log_level=error'"
msgstr ""
"%(prog)s --entrada input.mp4 --codificador libx265 --opciones codificador '-"
"crf 26 -configuración rápida -x265-params log_level=error'"

#, python-format
msgid "%(prog)s [options]"
msgstr "%(prog)s [opciones]"

msgid "Restore pixelated adult videos (JAV)"
msgstr "Procesar videos adultos pixelados (JAV)"

msgid "General"
msgstr "General"

msgid "Path to pixelated video file or directory containing video files"
msgstr ""
"Ruta del archivo pixelado o del directorio que contiene los archivos de vídeo"

msgid ""
"Path used to save output file(s). If path is a directory then file name will "
"be chosen automatically (see --output-file-pattern). If no output path was "
"given then the directory of the input file will be used"
msgstr ""
"Ruta utilizada para guardar los archivos de salida. Si la ruta es un "
"directorio, el nombre del archivo se elegirá automáticamente (véase --output-"
"file-pattern). Si no se ha especificado ninguna ruta de salida, se utilizará "
"el directorio del archivo de entrada"

#, python-format
msgid ""
"Directory for temporary video files during restoration process. "
"Alternatively, you can use the environment variable TMPDIR. (default: "
"%(default)s)"
msgstr ""
"Directorio temporal de los videos durante el procesado. Alternativamente, "
"puedes usar la variable de entorno TMPDIR. (Por defecto: %(default)s)"

#, python-format, python-brace-format
msgid ""
"Pattern used to determine output file name(s). Used when input is a "
"directory, or a file but no output path was specified. Must include the "
"placeholder '{orig_file_name}'. (default: %(default)s)"
msgstr ""
"Patrón utilizado para determinar el fichero de salida name(s). Se utiliza "
"cuando la entrada es un directorio o un fichero, pero la ruta de salida no "
"se especificó. Debe incluir un marcador de posición '{orig_file_name}'. (Por "
"defecto: %(default)s)"

#, python-format
msgid ""
"Device used for running Restoration and Detection models. Use \"--list-"
"devices\" to see what's available (default: %(default)s)"
msgstr ""
"Dispositivo usado para la restauración y detección de modelos. Usar \"--list-"
"devices\" para ver cual está disponible (Por defecto: %(default)s)"

#, python-format
msgid ""
"Reduces VRAM usage and may increase speed on modern GPUs, with negligible "
"quality difference. (default: %(default)s)"
msgstr ""
"Reduce el uso de la VRAM y puede incrementar la velocidad en GPUs modernas, "
"con insignificante diferencia de calidad. (Por defecto: %(default)s)"

msgid "List available devices and exit"
msgstr "Lista de dispositivos disponibles y salida"

msgid "Display version and exit"
msgstr "Mostrar versión y salir"

msgid "Show this help message and exit"
msgstr "Mostrar este mensaje y salir"

#, python-format
msgid ""
"Select encoding preset by name. Use \"--list-encoding-presets\" to see "
"what's available. Ignored if \"--encoder\" and \"--encoder-options\" are "
"used (default: %(default)s)"
msgstr ""
"Seleccionar configuración codificador por nombre. Usar \"--list-encoding-"
"presets\" para ver los disponibles. Ignorar si \"--encoder\" y \"--encoder-"
"options\" son usados used (Por defecto: %(default)s)"

msgid "List available encoding presets and exit"
msgstr "Lista configuración codificadores disponibles y salir"

#, python-format
msgid ""
"Select video encoder by name. Use \"--list-encoders\" to see what's "
"available. (default: %(default)s)"
msgstr ""
"Selecciona codificador de video por nombre Usar \"--lista-Codificadores\" "
"para ver los disponibles. (Por defecto: %(default)s)"

msgid "List available encoders and exit"
msgstr "Lista codificadores disponibles y salir"

#, python-format
msgid ""
"Space-separated list of options for the encoder set via \"--encoder\". Use "
"\"--list-encoder-options\" to see what's available. (default: %(default)s)"
msgstr ""
"Lista separada por espacios de opciones del codificador \"--encoder\". Usar "
"\"--list-encoder-options\" para ver disponibles. (default: %(default)s)"

msgid "List available options of the given encoder and exit"
msgstr "Enumera las opciones disponibles del codificador y sale"

#, python-format
msgid ""
"Allows playing the file while it's being written. Sets .mp4 mov flags "
"\"frag_keyframe+empty_moov+faststart\". (default: %(default)s)"
msgstr ""
"Permite reproducción mientras el fichero está siendo escrito. Establece .mp4 "
"mov flags \"frag_keyframe+empty_moov+faststart\". (Por defecto: %(default)s)"

msgid "Mosaic Restoration"
msgstr "Restauración de Mosaico"

msgid ""
"List available restoration models found in model weights directory and exit "
"(default location is './model_weights' if not overwritten by environment "
"variable LADA_MODEL_WEIGHTS_DIR)"
msgstr ""
"Lista disponible de modelos encontrados en el directorio y sali (La carpeta "
"por defecto es './model_weights' if not overwritten by environment variable "
"LADA_MODEL_WEIGHTS_DIR)"

#, python-format
msgid ""
"Name of detection model or path to model weights file. Use \"--list-mosaic-"
"restoration-models\" to see what's available. (default: %(default)s)"
msgstr ""
"Nombre modelo de detección o ruta de los modelos. Usar \"--list-mosaic-"
"restoration-models\" para ver disponibles. (default: %(default)s)"

msgid ""
"Path to restoration model configuration file. You'll not have to set this "
"unless you're training your own custom models"
msgstr ""
"Ruta al archivo de configuración del modelo de restauración. No tendrás que "
"configurarlo a menos que estés entrenando tus propios modelos personalizados"

#, python-format
msgid ""
"Maximum number of frames for restoration. Higher values improve temporal "
"stability. Lower values reduce memory footprint. If set too low flickering "
"could appear (default: %(default)s)"
msgstr ""
"Máximo número de fotogramas para la restauración. Valores altos mejoran la "
"estabilidad. Valores bajos reducen el consumo de memoria. Si se pone "
"demasiado bajo pueden aparecer parpadeos (Por defecto: %(default)s)"

msgid "Mosaic Detection"
msgstr "Detección de Mosaico"

#, python-format
msgid ""
"Name of detection model or path to model weights file. Use \"--list-mosaic-"
"detection-models\" to see what's available. (default: %(default)s)"
msgstr ""
"Nombre modelo detección o ruta del modelo. Usar \"--list-mosaic-detection-"
"models\" para ver disponibles. (Por defecto: %(default)s)"

msgid ""
"List available detection models found in model weights directory and exit "
"(default location is './model_weights' if not overwritten by environment "
"variable LADA_MODEL_WEIGHTS_DIR)"
msgstr ""
"Lista disponible de modelos de detección encontrada en el directorio y "
"salida (la ruta por defecto es './model_weights' si no es escrita por la "
"variable de entorno LADA_MODEL_WEIGHTS_DIR)"

#, python-format
msgid ""
"Detect and ignore areas of pixelated faces. Can prevent restoration "
"artifacts but may worsen detection of NSFW mosaics. Available for models v3 "
"and newer. (default: %(default)s)"
msgstr ""
"Detecta e ignora áreas con caras pixeladas. Puede prevenir la restauración "
"pero empeora la detección de áreas NSFW. Disponible para modelos v3 y más "
"nuevos. (Por defecto: %(default)s)"

msgid "Processing audio"
msgstr "Procesando Audio"

#, python-brace-format
msgid "GPU {device} selected but CUDA is not available"
msgstr "GPU {device} seleccionada pero CUDA no está disponible"

#, python-brace-format
msgid ""
"Invalid file name pattern. It must include the template string "
"'{orig_file_name}' and a file extension"
msgstr ""
"Patrón de nombre de archivo no válido. Debes incluir la cadena de plantilla "
"'{orig_file_name}' y una extensión de archivo"

msgid ""
"Invalid output directory. If input is a directory then --output must also be "
"set to a directory"
msgstr ""
"Directorio de salida no válido. Si la entrada es un directorio, entonces --"
"output también debe establecerse en un directorio"

#, python-brace-format
msgid "Invalid input. No file or directory at {input_path}"
msgstr "Entrada no válida. No existe el fichero o directorio en {input_path}"

#, python-brace-format
msgid "Temporary directory {temporary_path} doesn't exist. Creating…"
msgstr "Directorio Temporal {temporary_path} no existe. Creando…"

msgid "Invalid mosaic detection model"
msgstr "Modelo de detección inválido"

msgid "Invalid mosaic restoration model"
msgstr "Modelo de restauración inválido"

msgid "Invalid encoding preset"
msgstr "Configuración codificador inválida"

msgid ""
"Either \"--encoding-preset\" or \"--encoder\" together with \"--encoder-"
"options\" must be used"
msgstr ""
"Ya sea \"--encoding-preset\" o \"--encoder\" junto con \"--encoder-options\" "
"debe usarse"

msgid "Received Ctrl-C, stopping restoration."
msgstr "Ctrl-C detectado. Deteniendo Procesado."

msgid "Latest Lada restoration model. Recommended"
